{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "sibling-build-preset",
      "hidden": true,
      "description": "Use a sibling directory for the build based on the preset name",
      "binaryDir": "${sourceDir}/../build-${sourceDirName}-${presetName}"
    },
    {
      "name": "simh-using-vcpkg",
      "hidden": true,
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/vcpkg"
      }
    },
    {
      "name": "settings",
      "hidden": true,
      "displayName": "Common configure settings",
      "inherits": [ "sibling-build-preset", "simh-using-vcpkg" ]
    },
    {
      "name": "debug-build",
      "hidden": true,
      "description": "Set the build type to Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release-build",
      "hidden": true,
      "description": "Set the build type to Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "default",
      "displayName": "Configure with default settings",
      "inherits": [ "settings", "debug-build" ]
    },
    {
      "name": "release",
      "displayName": "Configure with release settings",
      "inherits": [ "settings", "release-build" ]
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "displayName": "Build with default settings",
      "configurePreset": "default"
    },
    {
      "name": "release",
      "displayName": "Build with release settings",
      "configurePreset": "release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "displayName": "Test with default settings",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "displayName": "Test with release settings",
      "description": "Skips some tests that are failing a diagnostic",
      "configurePreset": "release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "exclude": {
          "name": "simh-(vax[0-9]*|sel32)$"
        }
      }
    }
  ],
  "packagePresets": [
    {
      "name": "default",
      "displayName": "Package with default settings",
      "configurePreset": "default",
      "generators": [ "ZIP" ]
    },
    {
      "name": "release-linux",
      "displayName": "Package with release settings",
      "configurePreset": "release",
      "generators": [ "TGZ" ]
    },
    {
      "name": "release-windows",
      "displayName": "Package with release settings",
      "configurePreset": "release",
      "generators": [ "ZIP" ]
    }
  ],
  "workflowPresets": [
    {
      "name": "default",
      "displayName": "Workflow with default settings: configure, build and test",
      "steps": [
        {
          "type": "configure",
          "name": "default"
        },
        {
          "type": "build",
          "name": "default"
        },
        {
          "type": "test",
          "name": "default"
        }
      ]
    },
    {
      "name": "release-linux",
      "displayName": "Workflow with linux Release settings: configure, build, test and package",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        },
        {
          "type": "test",
          "name": "release"
        },
        {
          "type": "package",
          "name": "release-linux"
        }
      ]
    },
    {
      "name": "release-windows",
      "displayName": "Workflow with Windows Release settings: configure, build, test and package",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        },
        {
          "type": "test",
          "name": "release"
        },
        {
          "type": "package",
          "name": "release-windows"
        }
      ]
    }
  ]
}
