{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "sibling-build-preset",
      "hidden": true,
      "description": "Use a sibling directory for the build based on the preset name",
      "binaryDir": "${sourceDir}/../build-${sourceDirName}-${presetName}"
    },
    {
      "name": "subdir-build-preset",
      "hidden": true,
      "description": "Use a subdirectory for the build based on the preset name",
      "binaryDir": "${sourceDir}/build-${sourceDirName}-${presetName}"
    },
    {
      "name": "simh-using-vcpkg",
      "hidden": true,
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/vcpkg"
      }
    },
    {
      "name": "default",
      "displayName": "Configure with default settings",
      "inherits": [ "sibling-build-preset", "simh-using-vcpkg" ]
    },
    {
      "name": "release",
      "displayName": "Configure with release settings",
      "inherits": [ "subdir-build-preset", "simh-using-vcpkg" ],
      "cacheVariables": {
        "CMAKE_BUID_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "displayName": "Build with default settings",
      "configurePreset": "default"
    },
    {
      "name": "release",
      "displayName": "Build with release settings",
      "configurePreset": "release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "displayName": "Test with default settings",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "displayName": "Test with release settings",
      "description": "Skips some vax tests that are failing a diagnostic",
      "configurePreset": "release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "exclude": {
          "name": "simh-vax[0-9]*$"
        }
      }
    }
  ],
  "packagePresets": [
    {
      "name": "default",
      "displayName": "Package with default settings",
      "configurePreset": "default",
      "generators": [ "ZIP" ]
    },
    {
      "name": "release",
      "displayName": "Package with release settings",
      "configurePreset": "release",
      "generators": [ "ZIP" ]
    }
  ],
  "workflowPresets": [
    {
      "name": "default",
      "displayName": "Workflow with default settings: configure, build and test",
      "steps": [
        {
          "type": "configure",
          "name": "default"
        },
        {
          "type": "build",
          "name": "default"
        },
        {
          "type": "test",
          "name": "default"
        }
      ]
    },
    {
      "name": "release",
      "displayName": "Workflow with Release settings: configure, build, test and package",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        },
        {
          "type": "test",
          "name": "release"
        },
        {
          "type": "package",
          "name": "release"
        }
      ]
    }
  ]
}
